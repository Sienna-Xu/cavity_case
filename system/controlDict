FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     icoFoam;
startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         0.05;      // 运行时间极短，纯作性能 Benchmark
deltaT          0.001;     // 50个时间步
writeControl    timeStep;
writeInterval   50;        // 只在最后一步保存结果，减少I/O对计算时间的干扰
purgeWrite      0;
writeFormat     ascii;
writePrecision  6;
writeCompression off;
timeFormat      general;
timePrecision   6;
runTimeModifiable true;